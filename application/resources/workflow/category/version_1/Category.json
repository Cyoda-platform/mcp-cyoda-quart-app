{
  "version": "1.0",
  "name": "Category",
  "desc": "Category lifecycle workflow for pet categorization",
  "initialState": "initial_state",
  "active": true,
  "states": {
    "initial_state": {
      "transitions": [
        {
          "name": "create_category",
          "next": "draft",
          "manual": false,
          "processors": [
            {
              "name": "CreateCategoryProcessor",
              "executionMode": "ASYNC_NEW_TX",
              "config": {
                "attachEntity": true,
                "calculationNodesTags": "cyoda_application",
                "responseTimeoutMs": 3000,
                "retryPolicy": "FIXED"
              }
            }
          ]
        }
      ]
    },
    "draft": {
      "transitions": [
        {
          "name": "publish_category",
          "next": "active",
          "manual": true,
          "processors": [
            {
              "name": "PublishCategoryProcessor",
              "executionMode": "ASYNC_NEW_TX",
              "config": {
                "attachEntity": true,
                "calculationNodesTags": "cyoda_application",
                "responseTimeoutMs": 3000,
                "retryPolicy": "FIXED"
              }
            }
          ]
        }
      ]
    },
    "active": {
      "transitions": [
        {
          "name": "archive_category",
          "next": "archived",
          "manual": true,
          "processors": [
            {
              "name": "ArchiveCategoryProcessor",
              "executionMode": "ASYNC_NEW_TX",
              "config": {
                "attachEntity": true,
                "calculationNodesTags": "cyoda_application",
                "responseTimeoutMs": 3000,
                "retryPolicy": "FIXED"
              }
            }
          ]
        }
      ]
    },
    "archived": {
      "transitions": [
        {
          "name": "restore_category",
          "next": "active",
          "manual": true,
          "processors": [
            {
              "name": "RestoreCategoryProcessor",
              "executionMode": "ASYNC_NEW_TX",
              "config": {
                "attachEntity": true,
                "calculationNodesTags": "cyoda_application",
                "responseTimeoutMs": 3000,
                "retryPolicy": "FIXED"
              }
            }
          ]
        }
      ]
    }
  }
}
