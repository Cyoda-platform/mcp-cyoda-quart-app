{
  "version": "1.0",
  "name": "HNItem",
  "desc": "Workflow for managing Hacker News items through validation, storage, indexing and activation",
  "initialState": "initial_state",
  "active": true,
  "states": {
    "initial_state": {
      "transitions": [
        {
          "name": "auto_to_pending",
          "next": "pending",
          "manual": false
        }
      ]
    },
    "pending": {
      "transitions": [
        {
          "name": "validate_item",
          "next": "validated",
          "manual": true,
          "processors": [
            {
              "name": "ValidateItemProcessor",
              "executionMode": "ASYNC_NEW_TX",
              "config": {
                "attachEntity": true,
                "calculationNodesTags": "cyoda_application",
                "responseTimeoutMs": 3000,
                "retryPolicy": "FIXED"
              }
            }
          ]
        }
      ]
    },
    "validated": {
      "transitions": [
        {
          "name": "store_item",
          "next": "stored",
          "manual": true,
          "processors": [
            {
              "name": "StoreItemProcessor",
              "executionMode": "ASYNC_NEW_TX",
              "config": {
                "attachEntity": true,
                "calculationNodesTags": "cyoda_application",
                "responseTimeoutMs": 5000,
                "retryPolicy": "FIXED"
              }
            }
          ],
          "criterion": {
            "type": "function",
            "function": {
              "name": "IsValidItemCriterion",
              "config": {
                "attachEntity": true,
                "calculationNodesTags": "cyoda_application",
                "responseTimeoutMs": 2000,
                "retryPolicy": "FIXED"
              }
            }
          }
        }
      ]
    },
    "stored": {
      "transitions": [
        {
          "name": "index_item",
          "next": "indexed",
          "manual": true,
          "processors": [
            {
              "name": "IndexItemProcessor",
              "executionMode": "ASYNC_NEW_TX",
              "config": {
                "attachEntity": true,
                "calculationNodesTags": "cyoda_application",
                "responseTimeoutMs": 4000,
                "retryPolicy": "FIXED"
              }
            }
          ]
        }
      ]
    },
    "indexed": {
      "transitions": [
        {
          "name": "activate_item",
          "next": "active",
          "manual": true
        }
      ]
    },
    "active": {
      "transitions": []
    }
  }
}
