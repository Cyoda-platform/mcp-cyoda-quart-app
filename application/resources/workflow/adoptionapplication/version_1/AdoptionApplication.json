{
    "version": "1.0",
    "name": "AdoptionApplication Workflow",
    "desc": "Workflow for processing adoption applications",
    "initialState": "initial_state",
    "active": true,
    "states": {
        "initial_state": {
            "transitions": [
                {
                    "name": "transition_to_submitted",
                    "next": "submitted",
                    "manual": false,
                    "processors": [
                        {
                            "name": "ApplicationSubmissionProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "submitted": {
            "transitions": [
                {
                    "name": "transition_to_under_review",
                    "next": "under_review",
                    "manual": false,
                    "processors": [
                        {
                            "name": "ApplicationReviewStartProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                },
                {
                    "name": "transition_to_expired",
                    "next": "expired",
                    "manual": false,
                    "processors": [
                        {
                            "name": "ApplicationExpirationProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "under_review": {
            "transitions": [
                {
                    "name": "transition_to_approved",
                    "next": "approved",
                    "manual": false,
                    "processors": [
                        {
                            "name": "ApplicationApprovalProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                },
                {
                    "name": "transition_to_rejected",
                    "next": "rejected",
                    "manual": false,
                    "processors": [
                        {
                            "name": "ApplicationRejectionProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                },
                {
                    "name": "transition_to_expired",
                    "next": "expired",
                    "manual": false,
                    "processors": [
                        {
                            "name": "ApplicationExpirationProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "approved": {
            "transitions": []
        },
        "rejected": {
            "transitions": []
        },
        "expired": {
            "transitions": []
        }
    }
}