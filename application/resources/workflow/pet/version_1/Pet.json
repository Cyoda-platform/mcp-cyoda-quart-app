{
    "version": "1.0",
    "name": "Pet Workflow",
    "desc": "Description of the workflow for Pet",
    "initialState": "initial_state",
    "active": true,
    "states": {
        "initial_state": {
            "transitions": [
                {
                    "name": "transition_to_registered",
                    "next": "registered",
                    "manual": false,
                    "processors": [
                        {
                            "name": "PetRegistrationProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "registered": {
            "transitions": [
                {
                    "name": "transition_to_active",
                    "next": "active",
                    "manual": false,
                    "processors": [
                        {
                            "name": "PetActivationProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        },
                        {
                            "name": "PetValidationCriterion",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "active": {
            "transitions": [
                {
                    "name": "transition_to_inactive",
                    "next": "inactive",
                    "manual": true,
                    "processors": [
                        {
                            "name": "PetDeactivationProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                },
                {
                    "name": "transition_to_archived",
                    "next": "archived",
                    "manual": true,
                    "processors": [
                        {
                            "name": "PetArchivalProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "inactive": {
            "transitions": [
                {
                    "name": "transition_to_active",
                    "next": "active",
                    "manual": true,
                    "processors": [
                        {
                            "name": "PetReactivationProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                },
                {
                    "name": "transition_to_archived",
                    "next": "archived",
                    "manual": true,
                    "processors": [
                        {
                            "name": "PetArchivalProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "archived": {
            "transitions": []
        }
    }
}