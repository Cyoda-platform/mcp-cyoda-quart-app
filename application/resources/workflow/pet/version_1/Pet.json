{
    "version": "1.0",
    "name": "Pet Workflow",
    "desc": "Description of the workflow for Pet",
    "initialState": "initial_state",
    "active": true,
    "states": {
        "initial_state": {
            "transitions": [
                {
                    "name": "transition_to_available",
                    "next": "available",
                    "manual": false,
                    "processors": [
                        {
                            "name": "PetInitializationProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "available": {
            "transitions": [
                {
                    "name": "transition_to_pending",
                    "next": "pending",
                    "manual": true,
                    "processors": [
                        {
                            "name": "PetReservationProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                },
                {
                    "name": "transition_to_unavailable",
                    "next": "unavailable",
                    "manual": true,
                    "processors": [
                        {
                            "name": "PetUnavailableProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "pending": {
            "transitions": [
                {
                    "name": "transition_to_available",
                    "next": "available",
                    "manual": true,
                    "processors": [
                        {
                            "name": "PetReleaseProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                },
                {
                    "name": "transition_to_sold",
                    "next": "sold",
                    "manual": false,
                    "processors": [
                        {
                            "name": "PetSaleProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ],
                    "criterion": {
                        "type": "function",
                        "function": {
                            "name": "PetPaymentCriterion",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    }
                }
            ]
        },
        "sold": {
            "transitions": [
                {
                    "name": "transition_to_available",
                    "next": "available",
                    "manual": true,
                    "processors": [
                        {
                            "name": "PetReturnProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "unavailable": {
            "transitions": [
                {
                    "name": "transition_to_available",
                    "next": "available",
                    "manual": true,
                    "processors": [
                        {
                            "name": "PetAvailableProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        }
    }
}