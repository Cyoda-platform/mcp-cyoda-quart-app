{
  "version": "1.0",
  "name": "DataAnalysis",
  "desc": "Workflow for analyzing downloaded data using pandas",
  "initialState": "initial_state",
  "active": true,
  "states": {
    "initial_state": {
      "transitions": [
        {
          "name": "start_workflow",
          "next": "pending",
          "manual": false
        }
      ]
    },
    "pending": {
      "transitions": [
        {
          "name": "start_analysis",
          "next": "analyzing",
          "manual": true,
          "processors": [
            {
              "name": "analyze_data",
              "executionMode": "ASYNC_NEW_TX",
              "config": {
                "attachEntity": true,
                "calculationNodesTags": "cyoda_application",
                "responseTimeoutMs": 60000,
                "retryPolicy": "FIXED"
              }
            }
          ]
        }
      ]
    },
    "analyzing": {
      "transitions": [
        {
          "name": "analysis_finished",
          "next": "completed",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "analysis_complete",
              "config": {
                "attachEntity": true,
                "calculationNodesTags": "cyoda_application",
                "responseTimeoutMs": 5000,
                "retryPolicy": "FIXED"
              }
            }
          }
        }
      ]
    },
    "completed": {
      "transitions": []
    }
  }
}
