{
    "version": "1.0",
    "name": "Appointment Workflow",
    "desc": "Workflow for managing appointments in the Purrfect Pets system",
    "initialState": "initial_state",
    "active": true,
    "states": {
        "initial_state": {
            "transitions": [
                {
                    "name": "transition_to_scheduled",
                    "next": "scheduled",
                    "manual": false,
                    "processors": [
                        {
                            "name": "AppointmentSchedulingProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "scheduled": {
            "transitions": [
                {
                    "name": "transition_to_confirmed",
                    "next": "confirmed",
                    "manual": true,
                    "processors": [
                        {
                            "name": "AppointmentConfirmationProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ],
                    "criterion": {
                        "type": "function",
                        "function": {
                            "name": "AppointmentValidationCriterion",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    }
                },
                {
                    "name": "transition_to_cancelled",
                    "next": "cancelled",
                    "manual": true,
                    "processors": [
                        {
                            "name": "AppointmentCancellationProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "confirmed": {
            "transitions": [
                {
                    "name": "transition_to_in_progress",
                    "next": "in_progress",
                    "manual": true,
                    "processors": [
                        {
                            "name": "AppointmentStartProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                },
                {
                    "name": "transition_to_cancelled",
                    "next": "cancelled",
                    "manual": true,
                    "processors": [
                        {
                            "name": "AppointmentCancellationProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                },
                {
                    "name": "transition_to_no_show",
                    "next": "no_show",
                    "manual": true,
                    "processors": [
                        {
                            "name": "AppointmentNoShowProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "in_progress": {
            "transitions": [
                {
                    "name": "transition_to_completed",
                    "next": "completed",
                    "manual": true,
                    "processors": [
                        {
                            "name": "AppointmentCompletionProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "completed": {
            "transitions": [
                {
                    "name": "transition_to_end",
                    "next": "[End]",
                    "manual": false
                }
            ]
        },
        "cancelled": {
            "transitions": [
                {
                    "name": "transition_to_end",
                    "next": "[End]",
                    "manual": false
                }
            ]
        },
        "no_show": {
            "transitions": [
                {
                    "name": "transition_to_end",
                    "next": "[End]",
                    "manual": false
                }
            ]
        }
    }
}