{
    "version": "1.0",
    "name": "Staff Workflow",
    "desc": "Workflow for managing staff status and transitions.",
    "initialState": "initial_state",
    "active": true,
    "states": {
        "initial_state": {
            "transitions": [
                {
                    "name": "transition_to_active",
                    "next": "active",
                    "manual": false,
                    "processors": [
                        {
                            "name": "StaffOnboardingProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "active": {
            "transitions": [
                {
                    "name": "transition_to_on_leave",
                    "next": "on_leave",
                    "manual": true,
                    "processors": [
                        {
                            "name": "StaffLeaveProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                },
                {
                    "name": "transition_to_suspended",
                    "next": "suspended",
                    "manual": true,
                    "processors": [
                        {
                            "name": "StaffSuspensionProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                },
                {
                    "name": "transition_to_terminated",
                    "next": "terminated",
                    "manual": true,
                    "processors": [
                        {
                            "name": "StaffTerminationProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "on_leave": {
            "transitions": [
                {
                    "name": "transition_to_active",
                    "next": "active",
                    "manual": true,
                    "processors": [
                        {
                            "name": "StaffReturnProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "suspended": {
            "transitions": [
                {
                    "name": "transition_to_active",
                    "next": "active",
                    "manual": true,
                    "processors": [
                        {
                            "name": "StaffReinstateProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "terminated": {
            "transitions": []
        }
    }
}