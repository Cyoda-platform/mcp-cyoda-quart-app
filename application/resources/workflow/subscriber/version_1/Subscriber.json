{
    "version": "1.0",
    "name": "Subscriber Workflow",
    "desc": "Manages the lifecycle of a subscriber from registration to unsubscription.",
    "initialState": "initial_state",
    "active": true,
    "states": {
        "initial_state": {
            "transitions": [
                {
                    "name": "transition_to_pending_confirmation",
                    "next": "pending_confirmation",
                    "manual": false,
                    "processors": [
                        {
                            "name": "SubscriberRegistrationProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "pending_confirmation": {
            "transitions": [
                {
                    "name": "transition_to_active",
                    "next": "active",
                    "manual": false,
                    "processors": [
                        {
                            "name": "SubscriberConfirmationProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                },
                {
                    "name": "transition_to_unsubscribed_before_confirmation",
                    "next": "unsubscribed",
                    "manual": true,
                    "processors": [
                        {
                            "name": "SubscriberUnsubscribeProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "active": {
            "transitions": [
                {
                    "name": "transition_to_unsubscribed",
                    "next": "unsubscribed",
                    "manual": true,
                    "processors": [
                        {
                            "name": "SubscriberUnsubscribeProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "unsubscribed": {
            "transitions": [
                {
                    "name": "transition_to_end",
                    "next": "end_state",
                    "manual": false
                }
            ]
        },
        "end_state": {
            "transitions": []
        }
    }
}