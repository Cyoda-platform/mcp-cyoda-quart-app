{
    "version": "1.0",
    "name": "CommentAnalysisRequest Workflow",
    "desc": "Manages the lifecycle of a comment analysis request from creation to completion.",
    "initialState": "initial_state",
    "active": true,
    "states": {
        "initial_state": {
            "transitions": [
                {
                    "name": "transition_to_pending",
                    "next": "pending",
                    "manual": false
                }
            ]
        },
        "pending": {
            "transitions": [
                {
                    "name": "transition_to_fetching_comments",
                    "next": "fetching_comments",
                    "manual": false,
                    "processors": [
                        {
                            "name": "CommentAnalysisRequestInitProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "fetching_comments": {
            "transitions": [
                {
                    "name": "transition_to_analyzing",
                    "next": "analyzing",
                    "manual": false,
                    "processors": [
                        {
                            "name": "CommentAnalysisRequestFetchProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                },
                {
                    "name": "transition_to_failed",
                    "next": "failed",
                    "manual": false,
                    "processors": [
                        {
                            "name": "CommentAnalysisRequestFailProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "analyzing": {
            "transitions": [
                {
                    "name": "transition_to_sending_report",
                    "next": "sending_report",
                    "manual": false,
                    "processors": [
                        {
                            "name": "CommentAnalysisRequestAnalyzeProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                },
                {
                    "name": "transition_to_failed",
                    "next": "failed",
                    "manual": false,
                    "processors": [
                        {
                            "name": "CommentAnalysisRequestFailProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "sending_report": {
            "transitions": [
                {
                    "name": "transition_to_completed",
                    "next": "completed",
                    "manual": false,
                    "processors": [
                        {
                            "name": "CommentAnalysisRequestReportProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                },
                {
                    "name": "transition_to_failed",
                    "next": "failed",
                    "manual": false,
                    "processors": [
                        {
                            "name": "CommentAnalysisRequestFailProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "completed": {
            "transitions": [
                {
                    "name": "transition_to_end",
                    "next": "end",
                    "manual": false
                }
            ]
        },
        "failed": {
            "transitions": [
                {
                    "name": "transition_to_pending",
                    "next": "pending",
                    "manual": true,
                    "processors": [
                        {
                            "name": "CommentAnalysisRequestRetryProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        }
    }
}