{
    "active": true,
    "desc": "Workflow for processing Nobel laureates ingestion jobs",
    "initialState": "none",
    "name": "Nobel Laureates Job Workflow",
    "states": {
        "failed": {
            "transitions": [
                {
                    "manual": false,
                    "name": "transition_to_notified_subscribers",
                    "next": "notified_subscribers",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "executionMode": "ASYNC_NEW_TX",
                            "name": "notify_subscribers"
                        }
                    ]
                }
            ]
        },
        "ingesting": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "is_succeeded"
                        },
                        "type": "function"
                    },
                    "manual": false,
                    "name": "transition_to_succeeded",
                    "next": "succeeded",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "executionMode": "ASYNC_NEW_TX",
                            "name": "fetch_and_process_data"
                        }
                    ]
                },
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "is_failed"
                        },
                        "type": "function"
                    },
                    "manual": false,
                    "name": "transition_to_failed",
                    "next": "failed",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "executionMode": "ASYNC_NEW_TX",
                            "name": "fetch_and_process_data"
                        }
                    ]
                }
            ]
        },
        "none": {
            "transitions": [
                {
                    "manual": false,
                    "name": "transition_to_scheduled",
                    "next": "scheduled"
                }
            ]
        },
        "notified_subscribers": {
            "transitions": []
        },
        "scheduled": {
            "transitions": [
                {
                    "manual": false,
                    "name": "transition_to_ingesting",
                    "next": "ingesting",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "executionMode": "ASYNC_NEW_TX",
                            "name": "start_ingestion"
                        }
                    ]
                }
            ]
        },
        "succeeded": {
            "transitions": [
                {
                    "manual": false,
                    "name": "transition_to_notified_subscribers",
                    "next": "notified_subscribers",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "executionMode": "ASYNC_NEW_TX",
                            "name": "notify_subscribers"
                        }
                    ]
                }
            ]
        }
    },
    "version": "1.0"
}